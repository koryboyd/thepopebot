# ──────────────────────────────────────────────────────────────
# Local / Offline / Free / Unlimited mode hints
# ──────────────────────────────────────────────────────────────

# Use Ollama (local LLM server)
LLM_PROVIDER=openai
OPENAI_API_KEY=ollama              # dummy value – most local servers ignore it
OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Tell code / docs we want to avoid GitHub Actions / external APIs
RUN_LOCALLY=true
GITHUB_ACTIONS=false

# ============================================
# GitHub Configuration (for cloud mode, optional)
# ============================================
GH_OWNER=your_github_username
GH_REPO=thepopebot
GH_TOKEN=your_github_token

# ============================================
# Cloud LLM Keys (optional, for RUN_LOCALLY=false)
# ============================================
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_GENAI_API_KEY=your_google_genai_key_here

# ============================================
# Telegram (Optional)
# ============================================
# TELEGRAM_BOT_TOKEN=your_real_token_from_BotFather
# APP_URL=https://100.x.x.x.tailscale.net:3000   # example Tailscale address

# ============================================
# Database & Storage
# ============================================
DATABASE_URL=file:./data/local.db

# ============================================
# Security
# ============================================
AUTH_SECRET=your_random_secret_key_here

# ============================================
# Agent Configuration
# ============================================
MAX_ITERATIONS=5
MEMORY_RETENTION_DAYS=7
SUPERVISOR_POLL_INTERVAL=30000

# ============================================
# Development & Debugging
# ============================================
NODE_ENV=development
DEBUG=false
DEBUG_LOGS=false
VERBOSE=false

# ============================================
# Docker Configuration
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock